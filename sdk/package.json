{
  "name": "@graveyield/sdk",
  "version": "0.1.0",
  "description": "TypeScript salvor SDK for GraveYield Protocol — derelict-pool detection, certify-and-salvage flow, claim helpers.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/graveyieldprotocol/protocol.git",
    "directory": "sdk"
  },
  "homepage": "https://graveyield.xyz",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.6",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
