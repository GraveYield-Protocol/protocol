{
  "name": "@graveyield/indexer",
  "version": "0.1.0",
  "description": "Off-chain GraveScanner v2 indexer — discovers candidate derelict pools across Solana AMMs and surfaces them to salvors.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@graveyield/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
